<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI',sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 460px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            text-align: center;
        }

        .avatar {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 35px;
        }

        h2 {
            color: #2d3748;
            font-size: 26px;
            font-weight: 700;
        }

        .welcome {
            color: #667eea;
            font-size: 18px;
            font-weight: 600;
            margin: 8px 0 20px;
        }

        .session-box {
            background: #f7fafc;
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 25px;
            text-align: left;
        }

            .session-box p {
                color: #4a5568;
                font-size: 14px;
                margin-bottom: 8px;
            }

                .session-box p:last-child {
                    margin-bottom: 0;
                }

            .session-box span {
                font-weight: 700;
                color: #667eea;
            }

        .divider {
            height: 1px;
            background: #e2e8f0;
            margin: 20px 0;
        }

        .btn-logout {
            display: block;
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg, #fc8181, #e53e3e);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: all 0.3s;
        }

            .btn-logout:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(229,62,62,0.4);
            }
    </style>
</head>
<body>

    <div class="card">
        <div class="avatar">👨‍💼</div>
        <h2>Dashboard</h2>
        <p class="welcome">Welcome, @ViewBag.Username! 👋</p>

        <div class="session-box">
            <p>✅ Status: <span>Logged In</span></p>
            <p>👤 Username: <span>@ViewBag.Username</span></p>
            <p>🕐 Session: <span>Active (30 min timeout)</span></p>
        </div>

        <div class="divider"></div>

        <a href="/Account/Logout" class="btn-logout">🚪 Logout</a>
    </div>

</body>
</html>
