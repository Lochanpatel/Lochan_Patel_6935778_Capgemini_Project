<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI',sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg,#667eea 0%,#764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 500px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            text-align: center;
        }

        .avatar {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg,#667eea,#764ba2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            font-size: 35px;
        }

        h2 {
            color: #2d3748;
            font-size: 26px;
            font-weight: 700;
        }

        .welcome {
            color: #667eea;
            font-size: 18px;
            font-weight: 600;
            margin: 8px 0 25px;
        }

        .menu {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 25px;
        }

        .menu-btn {
            padding: 20px;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

            .menu-btn span {
                font-size: 28px;
            }

        .btn-student {
            background: #ebf4ff;
            color: #3182ce;
        }

        .btn-product {
            background: #f0fff4;
            color: #276749;
        }

        .btn-student:hover {
            background: #3182ce;
            color: white;
            transform: translateY(-2px);
        }

        .btn-product:hover {
            background: #276749;
            color: white;
            transform: translateY(-2px);
        }

        .divider {
            height: 1px;
            background: #e2e8f0;
            margin: 20px 0;
        }

        .btn-logout {
            display: block;
            width: 100%;
            padding: 13px;
            background: linear-gradient(135deg,#fc8181,#e53e3e);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: all 0.3s;
        }

            .btn-logout:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(229,62,62,0.4);
            }
    </style>
</head>
<body>
    <div class="card">
        <div class="avatar">👨‍💼</div>
        <h2>Dashboard</h2>
        <p class="welcome">Welcome, @ViewBag.Username! 👋</p>

        <div class="menu">
            <a href="/Student/Register" class="menu-btn btn-student">
                <span>🎓</span> Student Registration
            </a>
            <a href="/Product/Index" class="menu-btn btn-product">
                <span>📦</span> Product Management
            </a>
        </div>

        <div class="divider"></div>
        <a href="/Account/Logout" class="btn-logout">🚪 Logout</a>
    </div>
</body>
</html>