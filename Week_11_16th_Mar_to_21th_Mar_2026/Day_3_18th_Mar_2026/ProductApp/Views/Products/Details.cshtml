@model ProductApp.Models.Product

@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            @* ✅ Back button *@
            <a asp-action="Index" class="btn btn-outline-secondary mb-4">
                ← Back to Catalog
            </a>

            <div class="card shadow border-0">
                @* ✅ Large Product Image *@
                <img src="@Model.ImageUrl"
                     class="card-img-top"
                     alt="@Model.Name"
                     style="max-height:380px; object-fit:cover;"
                     onerror="this.src='https://placehold.co/800x380?text=No+Image'" />

                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <h2 class="fw-bold">@Model.Name</h2>
                        <span class="badge bg-success fs-5 px-3 py-2">
                            ₹@Model.Price.ToString("0.00")
                        </span>
                    </div>

                    <hr />

                    <h5 class="text-muted">📄 Description</h5>
                    <p class="lead">@Model.Description</p>

                    <hr />

                    @* ✅ Bootstrap Alert for availability *@
                    <div class="alert alert-info d-flex align-items-center">
                        <span class="me-2">✅</span>
                        <span>
                            This product is <strong>available</strong>
                            and ready to order.
                        </span>
                    </div>

                    <a asp-action="Index" class="btn btn-primary px-4">
                        🛍️ Back to All Products
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>