@page
@model EventApp.Pages.Events.IndexModel

<!DOCTYPE html>
<html>
<head>
    <title>Event Participants</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI',sans-serif;
        }

        body {
            min-height: 100vh;
            background: linear-gradient(135deg,#43cea2 0%,#185a9d 100%);
            padding: 40px 20px;
        }

        .top-bar {
            background: white;
            border-radius: 15px;
            padding: 20px 30px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            max-width: 900px;
            margin: 0 auto 25px;
        }

        .total-badge {
            background: linear-gradient(135deg,#43cea2,#185a9d);
            color: white;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 700;
        }

        .card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            max-width: 900px;
            margin: 0 auto;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }

        .card-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg,#43cea2,#185a9d);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 30px;
        }

        .card-header h2 {
            color: #2d3748;
            font-size: 26px;
            font-weight: 700;
        }

        .success-msg {
            background: #f0fff4;
            border: 1px solid #9ae6b4;
            border-radius: 10px;
            padding: 12px 16px;
            color: #276749;
            font-weight: 600;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 25px;
        }

        thead tr {
            background: linear-gradient(135deg,#43cea2,#185a9d);
            color: white;
        }

        thead th {
            padding: 14px 16px;
            text-align: left;
            font-size: 13px;
        }

            thead th:first-child {
                border-radius: 10px 0 0 10px;
            }

            thead th:last-child {
                border-radius: 0 10px 10px 0;
            }

        tbody tr {
            border-bottom: 1px solid #e2e8f0;
            transition: background 0.2s;
        }

            tbody tr:hover {
                background: #f7fafc;
            }

        tbody td {
            padding: 12px 16px;
            color: #4a5568;
            font-size: 13px;
        }

        .badge-id {
            background: linear-gradient(135deg,#43cea2,#185a9d);
            color: white;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }

        .event-badge {
            background: #ebf8f4;
            color: #276749;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        .btn-delete {
            background: #fed7d7;
            color: #c53030;
            border: none;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

            .btn-delete:hover {
                background: #fc8181;
                color: white;
            }

        .btn-register {
            display: inline-block;
            padding: 12px 25px;
            background: linear-gradient(135deg,#43cea2,#185a9d);
            color: white;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.3s;
        }

            .btn-register:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 25px rgba(67,206,162,0.5);
            }

        .empty-msg {
            text-align: center;
            color: #a0aec0;
            padding: 30px;
            font-size: 15px;
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <span style="color:#185a9d; font-size:16px; font-weight:600;">👥 Registered Participants</span>
        <span class="total-badge">🎯 Total: @Model.Registrations.Count</span>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="icon">🎪</div>
            <h2>Event Participants List</h2>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success-msg">✅ @TempData["SuccessMessage"]</div>
        }

        @if (Model.Registrations.Count == 0)
        {
            <div class="empty-msg">📭 No participants registered yet. Be the first!</div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Event</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Registrations)
                    {
                        <tr>
                            <td><span class="badge-id">@r.Id</span></td>
                            <td><strong>@r.ParticipantName</strong></td>
                            <td>@r.Email</td>
                            <td><span class="event-badge">@r.EventName</span></td>
                            <td>
                                @* ✅ OnPostDelete handler called via asp-page-handler *@
                                <form method="post" asp-page-handler="Delete" asp-route-id="@r.Id" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-delete"
                                            onclick="return confirm('Remove @r.ParticipantName?')">
                                        🗑️ Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <a href="/Events/Register" class="btn-register">📝 Register New Participant</a>
    </div>

</body>
</html>
