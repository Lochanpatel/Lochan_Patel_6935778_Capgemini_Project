@model UniversityManagement.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<h1>Course Details</h1>
<hr />

<div class="card" style="max-width:600px;">
    <div class="card-header bg-warning">
        <h4 class="mb-0">@Model.Title</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Course ID</dt>
            <dd class="col-sm-8">@Model.CourseId</dd>

            <dt class="col-sm-4">Credits</dt>
            <dd class="col-sm-8">@Model.Credits</dd>

            <dt class="col-sm-4">Instructor</dt>
            <dd class="col-sm-8">@Model.Instructor?.Name</dd>
        </dl>

        <h5 class="mt-3">Enrolled Students</h5>
        @if (Model.Enrollments.Any())
        {
            <table class="table table-sm table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Student</th>
                        <th>Grade</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var enrollment in Model.Enrollments)
                    {
                        <tr>
                            <td>@enrollment.Student?.FullName</td>
                            <td><span class="badge bg-primary">@enrollment.Grade</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No students enrolled yet.</p>
        }
    </div>
    <div class="card-footer">
        <a href="/Courses/Index" class="btn btn-secondary">Back to List</a>
        <a href="/Courses/Edit/@Model.CourseId" class="btn btn-warning ms-2">Edit</a>
    </div>
</div>