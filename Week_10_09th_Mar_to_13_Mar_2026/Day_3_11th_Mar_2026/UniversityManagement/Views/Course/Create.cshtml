@{
    ViewData["Title"] = "Add Course";
}

<h1>Add New Course</h1>
<hr />

<div class="card" style="max-width:500px;">
    <div class="card-body">
        <form method="post" action="/Courses/Create">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input type="text" name="Title" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Credits</label>
                <input type="number" name="Credits" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Instructor</label>
                <select name="InstructorId" class="form-select" required>
                    <option value="">-- Select Instructor --</option>
                    @foreach (var instructor in ViewBag.Instructors)
                    {
                        <option value="@instructor.InstructorId">@instructor.Name</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-success">Save Course</button>
            <a href="/Courses/Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>