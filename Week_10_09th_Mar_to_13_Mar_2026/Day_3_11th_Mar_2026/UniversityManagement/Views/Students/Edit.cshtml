@model UniversityManagement.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<h1>Edit Student</h1>
<hr />

<div class="card" style="max-width:500px;">
    <div class="card-body">
        <form method="post" action="/Students/Edit/@Model.StudentId">
            @Html.AntiForgeryToken()
            <input type="hidden" name="StudentId" value="@Model.StudentId" />
            <input type="hidden" name="EnrollmentDate" value="@Model.EnrollmentDate.ToString("yyyy-MM-dd")" />
            <div class="mb-3">
                <label class="form-label">Full Name</label>
                <input type="text" name="FullName" value="@Model.FullName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="Email" value="@Model.Email" class="form-control" required />
            </div>
            <button type="submit" class="btn btn-warning">Update Student</button>
            <a href="/Students/Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>