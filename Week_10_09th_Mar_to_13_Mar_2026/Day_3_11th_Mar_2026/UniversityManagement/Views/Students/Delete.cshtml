@model UniversityManagement.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<h1>Delete Student</h1>
<hr />

<div class="alert alert-danger">
    Are you sure you want to delete <strong>@Model.FullName</strong>?
    This will also delete all their enrollment records.
</div>

<div class="card" style="max-width:400px;">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.FullName</dd>

            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Email</dd>

            <dt class="col-sm-4">Enrolled in</dt>
            <dd class="col-sm-8">@Model.Enrollments.Count course(s)</dd>
        </dl>

        <form method="post" action="/Students/Delete/@Model.StudentId">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a href="/Students/Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>