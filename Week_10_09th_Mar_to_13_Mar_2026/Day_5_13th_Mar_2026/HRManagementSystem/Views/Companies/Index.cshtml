@model IEnumerable<HRManagementSystem.Models.Company>

@{
    ViewData["Title"] = "Companies";
}

<div style="max-width:900px; margin:30px auto; font-family:Segoe UI, sans-serif;">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h2 style="color:#2c3e50;">🏢 HR Management System</h2>
        <a href="/Companies/Create"
           style="background:#27ae60; color:white; padding:10px 20px;
                  border-radius:6px; text-decoration:none; font-weight:bold;">
            + Add Company
        </a>
    </div>

    @foreach (var company in Model)
    {
        <div style="border:1px solid #ddd; border-radius:10px;
                        padding:20px; margin-bottom:20px; background:#f9f9f9;">

            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h3 style="margin:0; color:#2980b9;">🏬 @company.Name</h3>
                    <small style="color:#777;">📍 @company.Location &nbsp;|&nbsp; 🏭 @company.Industry</small>
                </div>
                <div>
                    <a href="/Companies/Edit/@company.Id"
                       style="background:#f39c12; color:white; padding:6px 14px;
                                  border-radius:5px; text-decoration:none; margin-right:5px;">✏️ Edit</a>
                    <a href="/Companies/Delete/@company.Id"
                       style="background:#e74c3c; color:white; padding:6px 14px;
                                  border-radius:5px; text-decoration:none;">🗑️ Delete</a>
                </div>
            </div>

            <hr style="margin:15px 0;" />

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
                <h4 style="margin:0; color:#555;">👥 Employees (@company.Employees.Count)</h4>
                <a href="/Employees/Create?companyId=@company.Id"
                   style="background:#2980b9; color:white; padding:5px 12px;
                              border-radius:5px; text-decoration:none; font-size:13px;">
                    + Add Employee
                </a>
            </div>

            @if (company.Employees.Any())
            {
                <table style="width:100%; border-collapse:collapse; font-size:14px;">
                    <thead>
                        <tr style="background:#ecf0f1;">
                            <th style="padding:8px; text-align:left; border-bottom:1px solid #ddd;">Name</th>
                            <th style="padding:8px; text-align:left; border-bottom:1px solid #ddd;">Position</th>
                            <th style="padding:8px; text-align:left; border-bottom:1px solid #ddd;">Email</th>
                            <th style="padding:8px; text-align:left; border-bottom:1px solid #ddd;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var emp in company.Employees)
                        {
                            <tr style="border-bottom:1px solid #eee;">
                                <td style="padding:8px;">@emp.Name</td>
                                <td style="padding:8px;">@emp.Position</td>
                                <td style="padding:8px;">@emp.Email</td>
                                <td style="padding:8px;">
                                    <form method="post" action="/Employees/Delete/@emp.Id" style="display:inline;">
                                        <button type="submit"
                                                style="background:#e74c3c; color:white; border:none;
                                                                   padding:4px 10px; border-radius:4px; cursor:pointer;">
                                            🗑️ Remove
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p style="color:#aaa; font-style:italic;">No employees yet.</p>
            }
        </div>
    }
</div>