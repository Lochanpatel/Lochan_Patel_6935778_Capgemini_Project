@model StudentPortal.Models.StudentIndexViewModel

@{
    ViewData["Title"] = "Student Portal";
}

<h1>Student Portal</h1>
<p class="text-muted">Middleware + DI + Full CRUD Demo</p>
<hr />

<!-- ADD STUDENT FORM -->
<h2>Add New Student</h2>
<form method="post" action="/Students/Create" class="row g-2 mb-4">
    <div class="col-md-3">
        <input type="text" name="Name" class="form-control" placeholder="Name" required />
    </div>
    <div class="col-md-3">
        <input type="email" name="Email" class="form-control" placeholder="Email" required />
    </div>
    <div class="col-md-3">
        <input type="text" name="Course" class="form-control" placeholder="Course" required />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-success w-100">+ Add</button>
    </div>
</form>

<hr />

<!-- STUDENTS TABLE WITH INLINE EDIT + DELETE -->
<h2>Students</h2>
<table class="table table-bordered table-hover">
    <thead class="table-primary">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model.Students)
        {
            var formId = $"update-form-{student.Id}";
            <tr>
                <form id="@formId" method="post" action="/Students/Update" style="display:none">
                    <input type="hidden" name="Id" value="@student.Id" />
                </form>

                <td>@student.Id</td>
                <td><input type="text" name="Name" value="@student.Name" form="@formId" class="form-control form-control-sm" /></td>
                <td><input type="email" name="Email" value="@student.Email" form="@formId" class="form-control form-control-sm" /></td>
                <td><input type="text" name="Course" value="@student.Course" form="@formId" class="form-control form-control-sm" /></td>
                <td>
                    <button type="submit" form="@formId" class="btn btn-warning btn-sm">Update</button>

                    <form method="post" action="/Students/Delete" style="display:inline">
                        <input type="hidden" name="id" value="@student.Id" />
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('Delete @student.Name?')">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

<!-- REQUEST LOGS TABLE -->
<h2>CRUD Operation Logs <small class="text-muted">(tracked by middleware + controller)</small></h2>
@if (!Model.RequestLogs.Any())
{
    <p class="text-warning">No logs yet. Perform a CRUD operation to see entries.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-secondary">
            <tr>
                <th>Timestamp</th>
                <th>Operation</th>
                <th>URL</th>
                <th>Execution Time (ms)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.RequestLogs.OrderByDescending(l => l.Timestamp))
            {
                var badgeClass = log.Operation switch
                {
                    "CREATE" => "bg-success",
                    "UPDATE" => "bg-warning text-dark",
                    "DELETE" => "bg-danger",
                    _ => "bg-secondary"
                };
                <tr>
                    <td>@log.Timestamp.ToString("HH:mm:ss.fff")</td>
                    <td><span class="badge @badgeClass">@log.Operation</span></td>
                    <td>@log.Url</td>
                    <td>@log.ExecutionTimeMs ms</td>
                </tr>
            }
        </tbody>
    </table>
}