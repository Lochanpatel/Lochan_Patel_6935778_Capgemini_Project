@model IEnumerable<EmployeeProjectManagement.Models.Project>

<h2>Projects</h2>

<a href="/Projects/Create">Add Project</a>

<table class="table">

	<tr>
		<th>ID</th>
		<th>Title</th>
	</tr>

	@foreach (var item in Model)
	{
		<tr>
			<td>@item.ProjectId</td>
			<td>@item.Title</td>
		</tr>
	}

</table>